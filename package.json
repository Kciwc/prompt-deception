{
  "name": "prompt-deception",
  "version": "0.1.0",
  "private": true,
  "description": "Ceyon's Super Spiffy Non-Googleable Trivia — multiplayer party game",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build:client": "npm run build --workspace=client",
    "build": "npm install && npm run build:client",
    "start": "npm run start --workspace=server",
    "prisma:generate": "npm run prisma:generate --workspace=server",
    "prisma:migrate": "npm run prisma:migrate --workspace=server"
  }
}
