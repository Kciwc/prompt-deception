# Server port (Railway sets this automatically)
PORT=3001

# Origin allowed for CORS + socket.io. Use exact origin in prod, "*" only for local fiddling.
CLIENT_ORIGIN=http://localhost:5173

# Used to sign host tokens. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HOST_SECRET=

# Admin dashboard password (single shared password is fine — only you use it)
ADMIN_PASSWORD=

# Postgres (Railway provides this when you add the Postgres plugin)
DATABASE_URL=

# Cloudflare R2 — fill these once your bucket is set up
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prompt-deception-images
R2_PUBLIC_URL=
